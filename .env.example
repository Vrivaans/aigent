# AIgent v1.0 Local Configuration

# Backend API Port
PORT=3000

# Database Configuration (GORM) - Matches docker-compose.yml out of the box
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aigent
DB_SSLMODE=disable

# LLM Integration 
# (Obtén la tuya en https://openrouter.ai/keys)
OPENROUTER_API_KEY=tu_clave_de_openrouter_aqui

# HandsAI Java Backend Integration
# (Asegúrate de que HandsAI Java esté corriendo localmente en este puerto)
HANDSAI_URL=http://localhost:8080/mcp
HANDSAI_TOKEN=tu_token_handsai_aqui
