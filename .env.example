# AIgent v1.0 Local Configuration

# Backend API Port
PORT=3000

# Database Configuration (GORM) - Matches docker-compose.yml out of the box
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=aigent
DB_SSLMODE=disable

# LLM Security - Cifrado AES-256 (32 caracteres exactos)
# Este secreto se usa para cifrar las API Keys en la DB. ¡No lo pierdas!
DB_ENCRYPTION_KEY=tu_secreto_super_seguro_de_32char

# HandsAI Integration (The "Hands")
# URL del backend o servidor MCP que expone las herramientas
HANDSAI_URL=http://localhost:8080/mcp
HANDSAI_TOKEN=tu_token_handsai_aqui
